{
  "name": "controlador-mesa-rpi3",
  "version": "1.0.0",
  "description": "Controlador de mesa standing desk para Raspberry Pi 3",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",

    "service:start":   "sudo systemctl start pigpiod mesa-rpi",
    "service:stop":    "sudo systemctl stop mesa-rpi pigpiod",
    "service:restart": "sudo systemctl restart mesa-rpi",
    "service:status":  "sudo systemctl status pigpiod mesa-rpi --no-pager",

    "logs":        "sudo journalctl -u mesa-rpi -f",
    "logs:pigpio": "sudo journalctl -u pigpiod -f",
    "logs:all":    "sudo journalctl -u pigpiod -u mesa-rpi -f"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mqtt": "^5.3.4",
    "pigpio-client": "^1.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
